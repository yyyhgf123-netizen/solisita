      "max": 7,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "space_columns",
      "label": "Space between items (px)",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 30
    },

    {
      "type": "header",
      "content": "Screen 1200px – 1440px"
    },
    {
      "type": "range",
      "id": "column1440",
      "label": "Columns",
      "min": 1,
      "max": 7,
      "step": 0.5,
      "default": 4
    },
    {
      "type": "range",
      "id": "pergroup_column1440",
      "label": "Items per group",
      "min": 1,
      "max": 7,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "space_column1440",
      "label": "Space between items (px)",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 30
    },

    {
      "type": "header",
      "content": "Screen 992px – 1199px"
    },
    {
      "type": "range",
      "id": "column1",
      "label": "Columns",
      "min": 1,
      "max": 7,
      "step": 0.5,
      "default": 4
    },
    {
      "type": "range",
      "id": "pergroup_column1",
      "label": "Items per group",
      "min": 1,
      "max": 7,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "space_column1",
      "label": "Space between items (px)",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 15
    },

    {
      "type": "header",
      "content": "Screen 768px – 991px"
    },
    {
      "type": "range",
      "id": "column2",
      "label": "Columns",
      "min": 1,
      "max": 7,
      "step": 0.5,
      "default": 3
    },
    {
      "type": "range",
      "id": "pergroup_column2",
      "label": "Items per group",
      "min": 1,
      "max": 7,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "space_column2",
      "label": "Space between items (px)",
