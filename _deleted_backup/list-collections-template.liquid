    {
      "type": "header",
      "content": "Screen 480px – 767px"
    },
    {
      "type": "range",
      "id": "column3",
      "label": "Columns",
      "min": 1,
      "max": 7,
      "step": 0.5,
      "default": 1
    },
    {
      "type": "range",
      "id": "pergroup_column3",
      "label": "Items per group",
      "min": 1,
      "max": 7,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "space_column3",
      "label": "Space between items (px)",
