        "custom_liquid": "<div class=\"solisita-footer-social-row\">\n  <div class=\"solisita-footer-social-inner\">\n    <div class=\"solisita-footer-copy\">\n      <p>SOLISITA</p>\n      <p>© 2026 All Rights Reserved</p>\n    </div>\n\n    <div class=\"solisita-footer-icons\">\n      <span class=\"solisita-footer-icon\" aria-label=\"Instagram\">\n        <svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n          <path d=\"M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4c0 3.2-2.6 5.8-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8C2 4.6 4.6 2 7.8 2Zm0 2C5.7 4 4 5.7 4 7.8v8.4C4 18.3 5.7 20 7.8 20h8.4c2.1 0 3.8-1.7 3.8-3.8V7.8C20 5.7 18.3 4 16.2 4H7.8Zm4.2 3.2a4.8 4.8 0 1 1 0 9.6 4.8 4.8 0 0 1 0-9.6Zm0 2a2.8 2.8 0 1 0 0 5.6 2.8 2.8 0 0 0 0-5.6Zm5-2.35a1.15 1.15 0 1 1 0 2.3 1.15 1.15 0 0 1 0-2.3Z\"></path>\n        </svg>\n      </span>\n\n      <span class=\"solisita-footer-icon\" aria-label=\"Facebook\">\n        <svg width=\"9\" height=\"16\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n          <path d=\"M15.1 8.1h3.1l-.4 3.5h-2.7V22h-4.2V11.6H8V8.1h2.9V5.8c0-3 1.8-4.8 4.7-4.8 1.4 0 2.6.1 3 .2v3.3h-2c-1.2 0-1.5.6-1.5 1.5v2.1Z\"></path>\n        </svg>\n      </span>\n\n      <a href=\"https://www.tiktok.com/@solisita.uk\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"solisita-footer-icon\" aria-label=\"TikTok\">\n        <svg width=\"14\" height=\"16\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n          <path d=\"M17.5 6.2c1.3 1 2.8 1.6 4.5 1.7v3.6c-1.6 0-3.1-.4-4.5-1.2v6.2c0 3.5-2.9 6.5-6.5 6.5S4.5 20.1 4.5 16.5 7.4 10 11 10c.4 0 .8 0 1.2.1v3.7c-.4-.1-.8-.2-1.2-.2-1.6 0-2.8 1.3-2.8 2.8s1.3 2.8 2.8 2.8 2.8-1.3 2.8-2.8V1h3.7c.2 2.1 1.3 4 3 5.2h-3Z\"></path>\n        </svg>\n      </a>\n\n      <a href=\"https://pin.it/3YLb4XIza\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"solisita-footer-icon\" aria-label=\"Pinterest\">\n        <svg width=\"12\" height=\"15\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n          <path d=\"M12.2 1.8C6.9