    "custom_liquid_J94UVM": {
      "type": "custom-liquid",
      "name": "支付icon",
      "settings": {
        "custom_liquid": "<div id=\"solisita-payment-icons-source\">\n  <div class=\"solisita-payment-icons-wrap\">\n    <div class=\"solisita-payment-icons\">\n      {{ 'visa' | payment_type_svg_tag: class: 'solisita-payment-icons__icon' }}\n      {{ 'master' | payment_type_svg_tag: class: 'solisita-payment-icons__icon' }}\n      {{ 'american_express' | payment_type_svg_tag: class: 'solisita-payment-icons__icon' }}\n      {{ 'apple_pay' | payment_type_svg_tag: class: 'solisita-payment-icons__icon' }}\n      {{ 'google_pay' | payment_type_svg_tag: class: 'solisita-payment-icons__icon' }}\n      {{ 'shopify_pay' | payment_type_svg_tag: class: 'solisita-payment-icons__icon' }}\n      {{ 'klarna' | payment_type_svg_tag: class: 'solisita-payment-icons__icon' }}\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  function movePaymentIcons(){\n    var source=document.getElementById('solisita-payment-icons-source');\n    var wrap=document.querySelector('.solisita-payment-icons-wrap');\n    if(!source||!wrap)return false;\n    if(wrap.getAttribute('data-solisita-moved')==='true')return true;\n\n    var footer=document.querySelector('footer,.footer');\n    if(!footer)return false;\n\n    var nodes=[].slice.call(footer.querySelectorAll('*'));\n    var target=nodes.find(function(el){\n      return (el.textContent||'').replace(/\\s+/g,' ').trim()==='SOLISITA';\n    });\n\n    if(!target){\n      target=nodes.find(function(el){\n        return (el.textContent||'').replace(/\\s+/g,' ').trim().indexOf('© 2026 All Rights Reserved')>-1;\n      });\n    }\n\n    if(target){\n      target.insertAdjacentElement('beforebegin',wrap);\n      wrap.setAttribute('data-solisita-moved','true');\n      source.style.display='none';\n      source.style.height='0';\n      source.style.minHeight='0';\n      source.style.margin='0';\n      source.style.padding='0';\n      source.style.overflow='hidden';\n\n      var p=source.parentElement;\n      while(p&&p!==document.body&&p!==footer){\n        p.style.height='0';\n        p.style.minHeight='0';\n        p.style.margin='0';\n        p.style.padding='0';\n        p.style.overflow='visible';\n        p.style.background='transparent';\n        p=p.parentElement;\n      }\n      return true;\n    }\n\n    return false;\n  }\n\n  var tries=0;\n  var timer=setInterval(function(){\n    tries++;\n    if(movePaymentIcons()||tries>50)clearInterval(timer);\n  },200);\n\n  if(document.readyState==='loading'){\n    document.addEventListener('DOMContentLoaded',movePaymentIcons);\n  }else{\n    movePaymentIcons();\n  }\n})();\n</script>"
      }
    },
