        "custom_liquid": "<script>\n(function(){\n  function setMegaTop(){\n    var header=document.querySelector('.header-desktop');\n    if(!header)return;\n    var rect=header.getBoundingClientRect();\n    document.documentElement.style.setProperty('--solisita-mega-top',rect.bottom+'px');\n  }\n\n  function setHeaderScrollState(){\n    var isHome=document.body.classList.contains('template-index');\n    if(window.scrollY>12||!isHome){\n      document.body.classList.add('solisita-header-scrolled');\n    }else{\n      document.body.classList.remove('solisita-header-scrolled');\n    }\n    setMegaTop();\n  }\n\n  function markMegaMenuLayout(){\n    document.querySelectorAll('.menu-dropdown__content .menu-row').forEach(function(row){\n      var textIndex=0;\n      var bannerIndex=0;\n      Array.prototype.slice.call(row.children).forEach(function(block){\n        block.classList.remove(\n          'solisita-mm-text-block',\n          'solisita-mm-banner-block',\n          'solisita-mm-text-1',\n          'solisita-mm-text-2',\n          'solisita-mm-text-3',\n          'solisita-mm-text-4',\n          'solisita-mm-banner-1',\n          'solisita-mm-banner-2',\n          'solisita-mm-banner-3'\n        );\n        if(block.querySelector('.megamenu-banner')){\n          bannerIndex++;\n          block.classList.add('solisita-mm-banner-block','solisita-mm-banner-' + bannerIndex);\n        }else{\n          textIndex++;\n          block.classList.add('solisita-mm-text-block','solisita-mm-text-' + textIndex);\n        }\n      });\n    });\n  }\n\n  function initSolisitaHeader(){\n    markMegaMenuLayout();\n    setHeaderScrollState();\n    document.querySelectorAll('.menu-dropdown').forEach(function(item){\n      item.addEventListener('mouseenter',function(){\n        markMegaMenuLayout();\n        setMegaTop();\n      });\n    });\n  }\n\n  if(document.readyState==='loading'){\n    document.addEventListener('DOMContentLoaded',initSolisitaHeader);\n  }else{\n    initSolisitaHeader();\n  }\n\n  var solisitaMegaTries=0;\n  var solisitaMegaTimer=setInterval(function(){\n    solisitaMegaTries++;\n    markMegaMenuLayout();\n    setMegaTop();\n    if(solisitaMegaTries>10)clearInterval(solisitaMegaTimer);\n  },300);\n\n  window.addEventListener('resize',setHeaderScrollState);\n  window.addEventListener('scroll',setHeaderScrollState,{passive:true});\n})();\n</script>"
