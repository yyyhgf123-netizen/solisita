{%- assign nav = section.settings.navigation -%}
{%- assign infinite = section.settings.infinite -%}

{%- assign columns = section.settings.columns -%}
{%- assign space_columns = section.settings.space_columns -%}

{%- assign column1440 = section.settings.column1440 -%}
{%- assign space_column1440 = section.settings.space_column1440 -%}

{%- assign column1 = section.settings.column1 -%}
{%- assign space_column1 = section.settings.space_column1 -%}

{%- assign column2 = section.settings.column2 -%}
{%- assign space_column2 = section.settings.space_column2 -%}

{%- assign column3 = section.settings.column3 -%}
{%- assign space_column3 = section.settings.space_column3 -%}

{%- assign column4 = section.settings.column4 -%}
{%- assign space_column4 = section.settings.space_column4 -%}


{%- if section.settings.enable -%}
	{%- assign is_bg_image = section.settings.bgimage -%}
	{%- if is_bg_image -%}
		{%- assign class_name = 'wpbingo-breadcrumbs--image' -%}
	{%- else -%}
		{%- assign class_name = 'wpbingo-breadcrumbs--no-image' -%}
	{%- endif -%}
	<section class="wpbingo-section--{{ section.id }} {{ section.settings.align_breadcrumb }} wpbingo-breadcrumbs {{ class_name }}{% if section.settings.enable_collection %} have-collection{% endif %}" style="--color-breadcrumb:{{ section.settings.color_breadcrumb }}">
		{%- assign bg_image = section.settings.image -%}
		{%- if section.blocks.size > 0 -%}
			{%- for block in section.blocks -%}
				{%- if block.settings.collection == collection.handle -%}
					{%- assign bg_image = block.settings.bgimage -%}
					{%- break -%}
				{%- endif -%}
			{%- endfor -%}
		{%- endif -%}
		<div class="wpbingo-breadcrumbs__image"
			{%- if bg_image and is_bg_image -%}
			style="background-image: url('{{ bg_image | image_url:width:bg_image.width,height:bg_image.height }}');background-size:cover; background-position:center center"{%- endif -%}>
			<div class="container">
				<div class="wpbingo-breadcrumbs__inner">
					{%- if section.settings.show_pagetitle -%}<h2 class="wpbingo-breadcrumbs__title">{{ collection.title }}</h2>{%- endif -%}
					{%- if section.settings.show_breadcrumb -%}
					<ol class="breadcrumb" itemscope itemtype="http://schema.org/BreadcrumbList">
						<li class="breadcrumb__item" itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
							<a class="breadcrumb__link" href="/" title="{{ 'general.breadcrumbs.home_link_title' | t }}" itemprop="item">
								<span itemprop="name">{{ 'general.breadcrumbs.home_link_title' | t }}</span>
							</a>
							<meta itemprop="position" content="1" />
						</li>
						{%- if collection.handle == 'all' -%}
						<li class="breadcrumb__item active" itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
							<span class="breadcrumb__text">
								<span itemprop="name">{{ collection.title }}</span>
							</span>
							<meta itemprop="position" content="2" />
						</li>
						{%- else -%}
						<li class="breadcrumb__item" itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
							<a class="breadcrumb__link" href="/collections/all" title="{{ 'general.breadcrumbs.all_products_title' | t }}" itemprop="item">
								<span itemprop="name">{{ 'general.breadcrumbs.all_products_title' | t }}</span>
							</a>
							<meta itemprop="position" content="3" />
						</li>
						{%- if current_tags -%}
						  {% capture url %}/collections/{{ collection.handle }}{% endcapture %}
							<li class="breadcrumb__item" itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
								<a class="breadcrumb__link" href="{{ url }}" title="{{ collection.title }}" itemprop="item">
									<span itemprop="name">{{ collection.title }}</span>
								</a>
								<meta itemprop="position" content="3" />
							</li>
							<li class="breadcrumb__item active" itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
								<span class="breadcrumb__text">
									<span itemprop="name">{{ current_tags | join: " + " }}</span>
								</span>
								<meta itemprop="position" content="4" />
							</li>
						{%- else -%}
							<li class="breadcrumb__item active" itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
								<span class="breadcrumb__text">
									<span itemprop="name">{{ collection.title }}</span>
								</span>
								<meta itemprop="position" content="3" />
							</li>
						{%- endif -%}
					  {%- endif -%}
					</ol>
					{%- endif -%}
				</div>
			</div>
            {%- if section.settings.enable_collection and is_collection_page == blank -%}
              <div class="container">
                <div class="bwp_slider-carousel {{ section.settings.style_collection }}">
                  <div class="content-swiper-nav">
                      <div class="js-carousel  bwp-swiper-slider" data-infinite="{{ infinite }}"
                          data-columns="{{ columns }}"
                          data-space-columns="{{ space_columns }}"
      					data-column1440="{{ column1440 }}"
                          data-space-column1440="{{ space_column1440 }}"
      					data-column1="{{ column1 }}"
                          data-space-column1="{{ space_column1 }}"
      					data-column2="{{ column2 }}"
                          data-space-column2="{{ space_column2 }}"
      					data-column3="{{ column3 }}"
                          data-space-column3="{{ space_column3 }}"
      					data-column4="{{ column4 }}"
                          data-space-column4="{{ space_column4 }}">
                          <div class="swiper-wrapper">
                          {% for link in linklists[section.settings.categories_menu].links %}
                                  <div class="swiper-slide item-collection{% if request.path != blank and request.path == link.url %} active{% endif %}">
                                      {% assign collection_handle = link.url | split: '/' | last %}
                                      {% assign collection = collections[collection_handle] %}
                                      {%- if section.settings.style_collection == 'style_2' -%}
                                          {%- if collection.image -%}
                                              {%- assign collection_image = collection.image | image_url:width:200,height:200 -%}
                                          {%- else -%}
                                              {%- assign collection_image =  'placeholder.svg' | asset_url  -%}
                                          {%- endif -%}
                                      {%- else -%}
                                          {%- if collection.image -%}
                                              {%- assign collection_image = collection.image | image_url:width:collection.image.width,height:collection.image.height -%}
                                          {%- else -%}
                                              {%- assign collection_image =  'placeholder.svg' | asset_url -%}
                                          {%- endif -%}
                                      {%- endif -%}
                                      <a href="{{ link.url }}" title="{{ link.title | escape }}">
                                          <div class="image">
                                              <img class="lazyload fade-in" src="{{ collection_image }}" data-sizes="auto" data-image="true" alt="{{ collection_image.alt | escape }}" width="{{ collection_image.width }}" height="{{ collection_image.height }}">
                                          </div>
                                          <h2><span>{{ link.title }}</span></h2>
                                      </a>
                                  </div>
                          {%- endfor -%}
                          </div>
                          {%- if nav -%}
                      <button class="slick-prev slick-arrow" aria-label="Previous" type="button" style=""></button>
                      <button class="slick-next slick-arrow" aria-label="Next" type="button" style=""></button>
                      {%- endif -%}
                      </div>
                      
                  </div>
              </div>
              </div>
          {%- endif -%}
		</div>
	</section>
{%- endif -%}
{% schema %}
  {
    "name": "Breadcrumb",
    "settings": [
		{
			"type": "header",
			"content": "Settings"
		},
		{
			"type": "checkbox",
			"id": "enable",
			"label": "Enable",
			"default": true
		},
		{
			"type": "checkbox",
			"id": "bgimage",
			"label": "Use background image"
		},
		{
			"type": "image_picker",
			"id": "image",
			"label": "Background image default",
			"info": "Default size: 1920x720 pixels"
		},
		{
			"type": "checkbox",
			"id": "show_pagetitle",
			"label": "Show page title",
			"default": true
		},
		{
			"type": "checkbox",
			"id": "show_breadcrumb",
			"label": "Show breadcrumb",
			"default": true
		},
		{
			"type": "color",
			"id": "color_breadcrumb",
			"label": "Color breadcrumb",
			"default": "#000000"
		},
		{
			"type": "select",
			"id": "align_breadcrumb",
			"label": "Text align",
			"options": [
				{
					"value": "left",
					"label": "Left"
				},
				{
					"value": "right",
					"label": "Right"
				},
				{
					"value": "center",
					"label": "Center"
				}
			],
			"default": "left"
		},
		{
			"type": "header",
			"content": "Collection Settings"
		},
		{
			"type": "checkbox",
			"id": "enable_collection",
			"label": "Enable Collection",
			"default": true
		},
		{
			"type": "link_list",
			"id": "categories_menu",
			"label": "List Collection Menu"
		},
		{
			"type": "select",
			"id": "style_collection",
			"label": "Style Collection",
			"options": [
				{
					"value": "style_1",
					"label": "Style 1"
				},
				{
					"value": "style_2",
					"label": "Style 2"
				}
			],
			"default": "style_1"
		},
		{
			"type": "checkbox",
			"id": "navigation",
			"label": "Show navigation",
			"default": true
		},
		{
			"type": "checkbox",
			"id": "infinite",
			"label": "Infinite loop sliding",
			"default": true
		},
		{
          "type": "header",
          "content": "-----Screen >1440px"
        },
    	{
          "type": "range",
          "id": "columns",
          "min": 1,
          "max": 7,
          "step": 0.5,
          "label": "Columns",
          "default": 4
        },
        {
          "type": "range",
          "id": "space_columns",
          "min": 1,
          "max": 100,
          "step": 1,
          "label": "Space",
          "default": 30,
          "info": "px"
        },
        {
          "type": "header",
          "content": "-----Screen 1200px to 1440px"
        },
    	{
          "type": "range",
          "id": "column1440",
          "min": 1,
          "max": 7,
          "step": 0.5,
          "label": "Columns",
          "default": 4
        },
        {
          "type": "range",
          "id": "space_column1440",
          "min": 1,
          "max": 100,
          "step": 1,
          "label": "Space",
          "default": 30,
          "info": "px"
        },
        {
          "type": "header",
          "content": "-----Screen 992px to 1199px"
        },
        {
          "type": "range",
          "id": "column1",
          "min": 1,
          "max": 7,
          "step": 0.5,
          "label": "Columns",
          "default": 4
        },
        {
          "type": "range",
          "id": "space_column1",
          "min": 1,
          "max": 100,
          "step": 1,
          "label": "Space",
          "default": 15,
          "info": "px"
        },
        {
          "type": "header",
          "content": "-----Screen 768px to 991px"
        },
        {
          "type": "range",
          "id": "column2",
          "min": 1,
          "max": 7,
          "step": 0.5,
          "label": "Columns",
          "default": 3
        },
        {
          "type": "range",
          "id": "space_column2",
          "min": 1,
          "max": 100,
          "step": 1,
          "label": "Space",
          "default": 15,
          "info": "px"
        },
        {
          "type": "header",
          "content": "-----Screen 480px to 767px"
        },
        {
          "type": "range",
          "id": "column3",
          "min": 1,
          "max": 7,
          "step": 0.5,
          "label": "Columns",
          "default": 1
        },
        {
          "type": "range",
          "id": "space_column3",
          "min": 1,
          "max": 100,
          "step": 1,
          "label": "Space",
          "default": 15,
          "info": "px"
        },
         {
          "type": "header",
          "content": "-----Screen < 480px"
        },
    	{
          "type": "range",
          "id": "column4",
          "min": 1,
          "max": 7,
          "step": 0.5,
          "label": "Columns",
          "default": 1
        },
        {
          "type": "range",
          "id": "space_column4",
          "min": 1,
          "max": 100,
          "step": 1,
          "label": "Space",
          "default": 15,
          "info": "px"
        }
    ],
    "blocks": [
      {
        "type": "item",
        "name": "Background image",
        "settings": [
          {
            "type": "collection",
            "id": "collection",
            "label": "Collection"
          },
          {
            "type": "image_picker",
            "id": "bgimage",
            "label": "Background image",
            "info": "Image will be used in this collection"
          }
        ]
      },
      { "type": "@app" }
    ]
  }
{% endschema %}
