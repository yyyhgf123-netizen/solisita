    "custom_liquid_YtEnxb": {
      "type": "custom-liquid",
      "name": "FAQ",
      "settings": {
        "custom_liquid": "<section class=\"solisita-accordion\">\n  <div class=\"solisita-accordion__inner\">\n\n    <details class=\"solisita-accordion__item\">\n      <summary><span>High-Quality Jewellery</span><span class=\"solisita-accordion__icon\"></span></summary>\n      <div class=\"solisita-accordion__content\">\n        <p>Our jewellery designs are made for <strong>everyday moments</strong> and inspired by the way women wear their favourite pieces — from simple daily styling to meaningful finishing touches. Solisita creates <strong>high-quality jewellery</strong> designed to feel effortless, versatile and easy to wear again and again.</p>\n        <p><strong>Designed for everyday wear.</strong></p>\n      </div>\n    </details>\n\n    <details class=\"solisita-accordion__item\">\n      <summary><span>Why Solisita Jewellery?</span><span class=\"solisita-accordion__icon\"></span></summary>\n      <div class=\"solisita-accordion__content\">\n        <p>Every Solisita piece is selected with care, from <strong>necklaces</strong> and <strong>earrings</strong> to <strong>rings</strong>, <strong>bracelets</strong> and <strong>gift-ready sets</strong>. We focus on jewellery that feels beautiful, wearable and easy to style, whether you are choosing something for yourself or finding a thoughtful gift.</p>\n        <p>Our <strong>waterproof</strong> and <strong>tarnish-resistant</strong> pieces are designed to keep their shine through <strong>everyday wear</strong>, so you can enjoy jewellery that works with your routine — from busy days to slower weekends.</p>\n      </div>\n    </details>\n\n    <details class=\"solisita-accordion__item\">\n      <summary><span>Jewellery Made For Everyday Styling</span><span class=\"solisita-accordion__icon\"></span></summary>\n      <div class=\"solisita-accordion__content\">\n        <p>We design our collections around pieces you can reach for every day. From <strong>delicate necklaces</strong> and <strong>statement earrings</strong> to <strong>stackable rings</strong>, bracelets and <strong>jewellery sets</strong>, Solisita makes it easy to build a look that feels personal to you.</p>\n        <p>Whether you prefer simple gold tones, pearl-inspired details, colourful accents or <strong>gift-ready finishing touches</strong>, our jewellery is made to complement your wardrobe and bring a little shine to everyday life.</p>\n      </div>\n    </details>\n\n    <details class=\"solisita-accordion__item\">\n      <summary><span>Don’t be shy, say hello!</span><span class=\"solisita-accordion__icon\"></span></summary>\n      <div class=\"solisita-accordion__content\">\n        <p>If you need help with your order, product details or choosing the right piece, please get in touch with us through our <strong>contact page</strong>. We are always happy to help with questions about <strong>jewellery care</strong>, <strong>delivery</strong>, <strong>gifting</strong> and <strong>styling</strong>.</p>\n        <p>You can also follow Solisita for new arrivals, styling notes and everyday jewellery inspiration.</p>\n      </div>\n    </details>\n\n  </div>\n</section>\n\n"
      }
    },
