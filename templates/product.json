    "custom_liquid_jbnARV": {
      "type": "custom-liquid",
      "custom_css": [],
      "name": "单品页 liquid",
      "settings": {
        "custom_liquid": "{% assign sd_text = product.metafields.custom.short_description.value | default: product.description | strip_html %}\n{% assign detail_raw = product.metafields.custom.short_description.value %}\n{% assign mat = product.metafields.custom.materials.value %}\n{% assign fit = product.metafields.custom.size_fit.value %}\n{% assign solisita_bc_collection = collection %}\n{% if solisita_bc_collection == blank and product.collections.size > 0 %}\n  {% assign solisita_bc_collection = product.collections.first %}\n{% endif %}\n\n<div id=\"solisita-pdp-breadcrumb\" class=\"solisita-pdp-breadcrumb\">\n  <a href=\"/\">Home</a>\n  {% if solisita_bc_collection != blank %}\n    <span class=\"solisita-pdp-breadcrumb__sep\">•</span>\n    <a href=\"{{ solisita_bc_collection.url }}\">{{ solisita_bc_collection.title }}</a>\n  {% endif %}\n</div>\n\n<div id=\"solisita-pdp-readmore\" class=\"solisita-pdp-readmore\">\n  <div class=\"solisita-pdp-readmore__text\">\n    <span class=\"solisita-pdp-readmore__copy\" data-full-text=\"{{ sd_text | escape }}\">{{ sd_text | truncate: 80 }}</span>\n    <button type=\"button\" class=\"solisita-open-drawer solisita-pdp-readmore__btn\" data-panel=\"details\">Read more</button>\n  </div>\n</div>\n\n<div class=\"solisita-drawer-overlay\"></div>\n\n<aside class=\"solisita-details-drawer\" aria-hidden=\"true\">\n  <header class=\"solisita-details-drawer__header\">\n    <h2 class=\"solisita-details-drawer__title\" data-drawer-title>DETAILS</h2>\n    <button type=\"button\" class=\"solisita-details-drawer__close\" aria-label=\"Close\">\n      <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\">\n        <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M11.293 12L5.646 6.354l.708-.708L12 11.293l5.646-5.647.708.708L12.707 12l5.647 5.646-.708.708L12 12.707l-5.646 5.647-.708-.708L11.293 12Z\" fill=\"black\"/>\n      </svg>\n    </button>\n  </header>\n\n  <div class=\"solisita-details-drawer__scroll\">\n    <div class=\"solisita-drawer-panel\" data-panel-content=\"details\" data-panel-title=\"DETAILS\">\n      <div class=\"solisita-modal-content solisita-modal-content--details\">\n        {% if detail_raw != blank %}\n          {% if detail_raw contains '<' %}\n            {{ detail_raw }}\n          {% else %}\n            <div class=\"solisita-modal-section solisita-modal-section--dynamic\" data-detail-raw=\"{{ detail_raw | escape }}\">\n              <h3>THE SOLISITA TOUCH</h3>\n              <p>{{ detail_raw | newline_to_br }}</p>\n            </div>\n          {% endif %}\n        {% elsif product.description != blank %}\n          {{ product.description }}\n        {% endif %}\n\n        {% if mat != blank or fit != blank %}\n          <div class=\"solisita-modal-section\">\n            <h3>THE SPECS</h3>\n            <ul class=\"solisita-spec-list\">\n              {% if mat != blank %}\n                <li><strong>Material:</strong> {{ mat | newline_to_br }}</li>\n              {% endif %}\n              {% if fit != blank %}\n                <li><strong>Size & Fit:</strong> {{ fit | newline_to_br }}</li>\n              {% endif %}\n            </ul>\n          </div>\n        {% endif %}\n      </div>\n    </div>\n\n    <div class=\"solisita-drawer-panel\" data-panel-content=\"materials\" data-panel-title=\"MATERIALS & CARE\">\n      <div class=\"solisita-modal-content\">\n        <div class=\"solisita-care-block\">\n          <div class=\"solisita-care-heading\">\n            <span class=\"solisita-care-icon\">\n              <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\">\n                <circle cx=\"12\" cy=\"12\" r=\"10\" stroke=\"black\"/>\n                <circle cx=\"12\" cy=\"12\" r=\"5.5\" stroke=\"black\"/>\n                <path d=\"M7.5 15.5C8.2 15.5 9.28 15.4 10.26 15.07C11.2 14.76 12.22 14.19 12.49 13.12C12.76 12.01 12.62 11.04 12.42 10.25C12.24 9.52 12 8.93 12 8.5C12 7.81 12.3 7.02 12.45 6.72\" stroke=\"black\"/>\n                <path d=\"M14.5 17C14.28 16.64 14 15.85 14 15C14 14.18 14.2 13.23 14.9 12.8C15.65 12.34 16.55 12.38 17.5 13\" stroke=\"black\"/>\n              </svg>\n            </span>\n            <h3>Caring For Your Jewellery</h3>\n          </div>\n          <div class=\"solisita-care-text\">\n            <p>Most Solisita pieces are made with <strong>titanium steel as the main base material</strong>, chosen for everyday wear, durability and a comfortable feel.</p>\n            <p>Some pieces include decorative details such as <strong>crystals, cubic zirconia, faux pearls, enamel or other stone-effect accents</strong>. Please check the product details for the specific finish and decoration of each piece.</p>\n            <p>Selected pieces are <strong>waterproof</strong> and <strong>tarnish-resistant</strong>, making them suitable for daily styling. To keep your jewellery looking its best, we still recommend storing it in a cool, dry place and gently cleaning it with a soft, non-abrasive cloth.</p>\n            <p>Avoid harsh chemicals, perfumes, lotions and cleaning products where possible, as these may affect the finish over time.</p>\n          </div>\n        </div>\n\n        <div class=\"solisita-modal-divider\"></div>\n\n        <div class=\"solisita-care-block\">\n          <div class=\"solisita-care-heading\">\n            <span class=\"solisita-care-icon\">\n              <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\">\n                <path d=\"M4 8h16v12H4V8Z\" stroke=\"black\"/>\n                <path d=\"M4 8l8 5 8-5\" stroke=\"black\"/>\n                <path d=\"M12 8V5.5C12 4.12 10.88 3 9.5 3S7 4.12 7 5.5C7 6.88 8.12 8 9.5 8H12Z\" stroke=\"black\"/>\n                <path d=\"M12 8V5.5C12 4.12 13.12 3 14.5 3S17 4.12 17 5.5C17 6.88 15.88 8 14.5 8H12Z\" stroke=\"black\"/>\n              </svg>\n            </span>\n            <h3>Gift-Ready Packaging</h3>\n          </div>\n          <div class=\"solisita-care-text\">\n            <p>Your order will be packed in either a <strong>complimentary gift box</strong> or a <strong>jewellery pouch</strong>, depending on the piece. Designed to feel thoughtful whether you are treating yourself or gifting someone special.</p>\n          </div>\n        </div>\n\n        <div class=\"solisita-modal-divider\"></div>\n\n        <div class=\"solisita-care-block\">\n          <div class=\"solisita-care-heading\">\n            <span class=\"solisita-care-icon\">\n              <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\">\n                <circle cx=\"12\" cy=\"8\" r=\"4\" stroke=\"black\"/>\n                <path d=\"M8 12v9l4-2.5 4 2.5v-9\" stroke=\"black\"/>\n              </svg>\n            </span>\n            <h3>Warranty</h3>\n          </div>\n          <div class=\"solisita-care-text\">\n            <p>Solisita jewellery comes with a <strong>1-year warranty</strong> covering manufacturing faults. This does not cover general wear and tear, accidental damage, loss, or damage caused by improper care.</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"solisita-drawer-panel\" data-panel-content=\"shipping\" data-panel-title=\"SHIPPING & RETURNS\">\n      <div class=\"solisita-modal-content\">\n        <table class=\"solisita-shipping-table\">\n          <tbody>\n            <tr>\n              <th>Shipping Method</th>\n              <th>Cost</th>\n              <th>Timeframe</th>\n            </tr>\n            <tr>\n              <td>UK Standard Delivery<br><span>UK only</span></td>\n              <td>Free on orders over £59<br>£4.99 on orders below</td>\n              <td>7–10 working days</td>\n            </tr>\n            <tr>\n              <td>Next Day Delivery</td>\n              <td>Not currently available</td>\n              <td>—</td>\n            </tr>\n            <tr>\n              <td>International Delivery</td>\n              <td>Not currently available</td>\n              <td>—</td>\n            </tr>\n          </tbody>\n        </table>\n\n        <p class=\"solisita-modal-note\"><em>Orders are processed within <strong>1–3 business days</strong>. Standard UK delivery usually takes <strong>7–10 working days</strong> after dispatch.</em></p>\n\n        <div class=\"solisita-modal-divider\"></div>\n\n        <h3 class=\"solisita-block-title\">RETURNS</h3>\n        <div class=\"solisita-richtext\">\n          <p>We hope you love your Solisita piece. If it is not quite right, eligible items can be returned within <strong>14 days</strong> of receiving your order.</p>\n          <p>Items must be <strong>unworn, unused and returned in their original packaging</strong>. UK returns are free for eligible items.</p>\n          <p>For hygiene reasons, <strong>earrings cannot be returned unless faulty</strong>. Personalised or custom-made items are also <strong>non-returnable unless faulty</strong>.</p>\n        </div>\n      </div>\n    </div>\n  </div>\n</aside>\n\n<div id=\"solisita-pdp-icons\" class=\"solisita-pdp-icons\">\n  <div class=\"solisita-pdp-icons__item\">\n    <span class=\"solisita-pdp-icons__icon\">\n      <svg width=\"24\" height=\"25\" viewBox=\"0 0 24 25\" fill=\"none\">\n        <path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M20 6.97L12.23 4.83L4.45 6.97V9.83H5.27V8.08L11.82 10.06V19.1L5.27 17.11V15.33H4.45V17.73L11.82 19.96L12.23 20.08L12.64 19.96L20 17.73V6.97ZM18.56 7.4L12.23 5.64L5.89 7.4L12.23 9.32L18.56 7.4ZM12.64 10.06V19.1L19.18 17.11V8.08L12.64 10.06ZM1 11.08H7.5V11.83H1V11.08ZM7.5 13.33H2V14.08H7.5V13.33Z\" fill=\"black\"/>\n      </svg>\n    </span>\n    <p>Standard UK Shipping £4.99, FREE over £59</p>\n  </div>\n\n  <div class=\"solisita-pdp-icons__item\">\n    <span class=\"solisita-pdp-icons__icon\">\n      <svg width=\"24\" height=\"25\" viewBox=\"0 0 24 25\" fill=\"none\">\n        <circle cx=\"12\" cy=\"8.5\" r=\"4\" stroke=\"black\"/>\n        <path d=\"M8 12.5v9l4-2.5l4 2.5v-9\" stroke=\"black\"/>\n        <path d=\"M10.2 8.5l1.2 1.2l2.4-2.6\" stroke=\"black\"/>\n      </svg>\n    </span>\n    <p>1 Year Warranty</p>\n  </div>\n\n  <div class=\"solisita-pdp-icons__item\">\n    <span class=\"solisita-pdp-icons__icon\">\n      <svg width=\"24\" height=\"25\" viewBox=\"0 0 24 25\" fill=\"none\">\n        <path d=\"M7 7.5H4V4.5\" stroke=\"black\"/>\n        <path d=\"M4 7.5C5.6 4.9 8.5 3.5 11.7 3.9C16.2 4.4 19.5 8.2 19.5 12.5C19.5 17.2 15.7 21 11 21C8.1 21 5.6 19.6 4 17.4\" stroke=\"black\"/>\n        <path d=\"M8 12.5H16\" stroke=\"black\"/>\n        <path d=\"M13 9.5L16 12.5L13 15.5\" stroke=\"black\"/>\n      </svg>\n    </span>\n    <p>14-Day Returns</p>\n  </div>\n\n  <div class=\"solisita-pdp-icons__item\">\n    <span class=\"solisita-pdp-icons__icon\">\n      <svg width=\"24\" height=\"25\" viewBox=\"0 0 24 25\" fill=\"none\">\n        <path d=\"M4 8.5H20V20.5H4V8.5Z\" stroke=\"black\"/>\n        <path d=\"M4 8.5L12 13.5L20 8.5\" stroke=\"black\"/>\n        <path d=\"M12 8.5V20.5\" stroke=\"black\"/>\n        <path d=\"M12 8.5V6C12 4.62 10.88 3.5 9.5 3.5S7 4.62 7 6C7 7.38 8.12 8.5 9.5 8.5H12Z\" stroke=\"black\"/>\n        <path d=\"M12 8.5V6C12 4.62 13.12 3.5 14.5 3.5S17 4.62 17 6C17 7.38 15.88 8.5 14.5 8.5H12Z\" stroke=\"black\"/>\n      </svg>\n    </span>\n    <p>Gift-ready packaging</p>\n  </div>\n</div>\n\n<script>\n(function(){\nfunction cleanPdpText(text){\nif(!text)return'';\nvar t=String(text).replace(/\\r\\n/g,'\\n').replace(/\\r/g,'\\n').trim();\nt=t.replace(/^THE SOLISITA TOUCH\\s*/i,'');\nt=t.replace(/^DETAILS\\s*&?\\s*DIMENSIONS\\s*/i,'');\nt=t.replace(/^DESCRIPTION\\s*/i,'');\nt=t.replace(/\\n+/g,' ');\nt=t.replace(/\\s+/g,' ').trim();\nreturn t;\n}\n\nfunction smartTrimText(text,limit){\nif(!text)return'';\nvar clean=cleanPdpText(text);\nvar chars=Array.from(clean);\nif(chars.length<=limit)return clean;\nvar cut=chars.slice(0,limit).join('');\nvar marks=['.','!','?','。','！','？'];\nvar best=-1;\nmarks.forEach(function(m){best=Math.max(best,cut.lastIndexOf(m))});\nif(best>36)return cut.slice(0,best+1);\nvar space=cut.lastIndexOf(' ');\nif(space>42)return cut.slice(0,space);\nreturn cut.replace(/[,\\.;:\\-\\s，。；：、]+$/,'');\n}\n\nfunction setupReadmoreCopy(){\nvar el=document.querySelector('.solisita-pdp-readmore__copy');\nif(!el||el.getAttribute('data-trimmed')==='true')return;\nvar full=el.getAttribute('data-full-text')||el.textContent||'';\nvar clean=cleanPdpText(full);\nvar trimmed=smartTrimText(clean,92);\nif(Array.from(clean).length>Array.from(trimmed).length){el.textContent=trimmed+'...'}else{el.textContent=trimmed}\nel.setAttribute('data-trimmed','true');\n}\n\nfunction escapeHtml(str){\nreturn String(str).replace(/[&<>\"']/g,function(s){return{'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',\"'\":'&#039;'}[s]});\n}\n\nfunction formatLines(str){return escapeHtml(str).replace(/\\n/g,'<br>')}\n\nfunction buildDetailSections(){\nvar block=document.querySelector('.solisita-modal-section--dynamic');\nif(!block||block.getAttribute('data-built')==='true')return;\nvar raw=block.getAttribute('data-detail-raw')||'';\nraw=raw.replace(/\\r\\n/g,'\\n').replace(/\\r/g,'\\n').trim();\nif(!raw)return;\nvar parts=raw.split(/\\n\\s*\\n+/).filter(function(item){return item.trim()!==''});\nif(parts.length<2){block.setAttribute('data-built','true');return}\nvar html='';\nparts.forEach(function(part,index){\nvar lines=part.split('\\n').map(function(line){return line.trim()}).filter(Boolean);\nif(!lines.length)return;\nvar title='THE SOLISITA TOUCH';\nvar body=part.trim();\nif(lines.length>1&&lines[0].length<=42){title=lines[0];body=lines.slice(1).join('\\n')}else if(index>0){title='DETAILS'}\nhtml+='<div class=\"solisita-modal-section\"><h3>'+escapeHtml(title)+'</h3><p>'+formatLines(body)+'</p></div>';\n});\nif(html){block.insertAdjacentHTML('afterend',html);block.remove()}\n}\n\nfunction hideThemeBreadcrumb(){\ndocument.querySelectorAll('ol.breadcrumb,.breadcrumb').forEach(function(el){\nif(el.classList.contains('solisita-pdp-breadcrumb'))return;\nif(el.closest('.solisita-details-drawer'))return;\nel.style.display='none';\nel.style.height='0';\nel.style.minHeight='0';\nel.style.margin='0';\nel.style.padding='0';\nel.style.overflow='hidden';\nvar p=el.parentElement;\nif(p&&p!==document.body){\nvar pt=(p.textContent||'').replace(/\\s+/g,'').trim();\nvar et=(el.textContent||'').replace(/\\s+/g,'').trim();\nif(pt===et){\np.style.display='none';\np.style.height='0';\np.style.minHeight='0';\np.style.margin='0';\np.style.padding='0';\np.style.overflow='hidden';\n}\n}\n});\n}\n\nfunction moveSolisitaBreadcrumb(){\nvar crumb=document.getElementById('solisita-pdp-breadcrumb');\nvar title=document.querySelector('.product-single__title,.product_title,.product-title,.single-product-title,h1.product-single__title,h2.product-single__title');\nif(!crumb||!title)return false;\nvar titleBox=title.closest('.shopify-block')||title;\nif(titleBox.previousElementSibling!==crumb){titleBox.insertAdjacentElement('beforebegin',crumb)}\ncrumb.style.display='flex';\nreturn true;\n}\n\nfunction movePriceUnderTitle(){\nvar title=document.querySelector('.product-single__title,.product_title,.product-title,.single-product-title,h1.product-single__title,h2.product-single__title');\nvar price=document.querySelector('.price-container');\nif(!title||!price)return false;\nif(price.closest('.solisita-details-drawer'))return false;\nvar titleBox=title.closest('.shopify-block')||title;\nif(titleBox.nextElementSibling!==price){titleBox.insertAdjacentElement('afterend',price)}\nprice.style.display='flex';\nreturn true;\n}\n\nfunction openDrawer(panel){\nvar drawer=document.querySelector('.solisita-details-drawer');\nvar ov=document.querySelector('.solisita-drawer-overlay');\nif(!drawer||!ov)return;\ndocument.querySelectorAll('.solisita-drawer-panel').forEach(function(el){el.classList.remove('is-active')});\nvar active=document.querySelector('.solisita-drawer-panel[data-panel-content=\"'+panel+'\"]');\nif(active){\nactive.classList.add('is-active');\nvar title=active.getAttribute('data-panel-title')||'DETAILS';\nvar titleEl=drawer.querySelector('[data-drawer-title]');\nif(titleEl)titleEl.textContent=title;\n}\ndrawer.classList.add('is-open');\nov.classList.add('is-open');\ndrawer.setAttribute('aria-hidden','false');\ndocument.body.style.overflow='hidden';\n}\n\nfunction closeDrawer(){\nvar drawer=document.querySelector('.solisita-details-drawer');\nvar ov=document.querySelector('.solisita-drawer-overlay');\nif(!drawer||!ov)return;\ndrawer.classList.remove('is-open');\nov.classList.remove('is-open');\ndrawer.setAttribute('aria-hidden','true');\ndocument.body.style.overflow='';\n}\n\nfunction moveReadmore(){\nvar box=document.getElementById('solisita-pdp-readmore');\nvar price=document.querySelector('.price-container');\nif(!box||!price)return false;\nprice.insertAdjacentElement('afterend',box);\nbox.style.display='block';\nreturn true;\n}\n\nfunction moveIcons(){\nvar icons=document.getElementById('solisita-pdp-icons');\nif(!icons)return false;\nvar infos=[].slice.call(document.querySelectorAll('.product-more-info')).filter(function(el){return !el.closest('.solisita-details-drawer')&&el.offsetParent!==null});\nif(infos.length){\nvar lastInfo=infos[infos.length-1];\nlastInfo.insertAdjacentElement('afterend',icons);\nicons.style.display='block';\nreturn true;\n}\nvar tabs=[].slice.call(document.querySelectorAll('.single-product-tabs,.product-tabs')).filter(function(el){return !el.closest('.solisita-details-drawer')&&el.offsetParent!==null});\nif(tabs.length){\nvar lastTabs=tabs[tabs.length-1];\nlastTabs.insertAdjacentElement('afterend',icons);\nicons.style.display='block';\nreturn true;\n}\nreturn false;\n}\n\nhideThemeBreadcrumb();\nmoveSolisitaBreadcrumb();\nmovePriceUnderTitle();\nsetupReadmoreCopy();\nbuildDetailSections();\n\nvar tries=0;\nvar timer=setInterval(function(){\ntries++;\nhideThemeBreadcrumb();\nmoveSolisitaBreadcrumb();\nmovePriceUnderTitle();\nsetupReadmoreCopy();\nbuildDetailSections();\nvar movedReadmore=moveReadmore();\nvar movedIcons=moveIcons();\nif((movedReadmore&&movedIcons)||tries>40)clearInterval(timer);\n},200);\n\ndocument.addEventListener('click',function(e){\nvar btn=e.target.closest('.solisita-open-drawer');\nvar close=e.target.closest('.solisita-details-drawer__close');\nvar overlay=e.target.closest('.solisita-drawer-overlay');\nif(btn){e.preventDefault();openDrawer(btn.getAttribute('data-panel')||'details');return}\nif(close||overlay){e.preventDefault();closeDrawer();return}\nvar tab=e.target.closest('.product-more-info .collapse_title,.product-more-info [data-toggle=\"collapse\"],.product-more-info [data-bs-toggle=\"collapse\"],.product-more-info .accordion-button');\nif(tab){\nvar text=(tab.textContent||'').toLowerCase();\ne.preventDefault();\ne.stopPropagation();\nif(text.indexOf('shipping')>-1||text.indexOf('returns')>-1){openDrawer('shipping')}else if(text.indexOf('material')>-1||text.indexOf('care')>-1){openDrawer('materials')}else{openDrawer('details')}\n}\n},true);\n\ndocument.addEventListener('keydown',function(e){if(e.key==='Escape')closeDrawer()});\n})();\n</script>"
      }
    },
