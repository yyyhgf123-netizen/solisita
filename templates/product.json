    "custom_liquid_i3K4fE": {
      "type": "custom-liquid",
      "custom_css": [],
      "name": "主页产品滚动liquid",
      "settings": {
        "custom_liquid": "{% assign related_collection = collections['all'] %}\n{% assign shown_count = 0 %}\n\n{% if related_collection != blank and related_collection.products_count > 1 %}\n<section class=\"solisita-you-may-like\" data-solisita-slider>\n  <div class=\"solisita-you-may-like__head\">\n    <h2>YOU MAY ALSO LIKE</h2>\n    <div class=\"solisita-you-may-like__arrows\">\n      <button type=\"button\" class=\"solisita-you-may-like__prev\" aria-label=\"Previous\">\n        <svg width=\"9\" height=\"16\" viewBox=\"0 0 9 16\" fill=\"none\"><path d=\"M9 15.266L1.51267 8L9 .733978L8.24367 0L0 8L8.24367 16L9 15.266Z\" fill=\"black\"/></svg>\n      </button>\n      <button type=\"button\" class=\"solisita-you-may-like__next\" aria-label=\"Next\">\n        <svg width=\"9\" height=\"16\" viewBox=\"0 0 9 16\" fill=\"none\"><path d=\"M0 15.266L7.48733 8L0 .733978L.756335 0L9 8L.756335 16L0 15.266Z\" fill=\"black\"/></svg>\n      </button>\n    </div>\n  </div>\n\n  <div class=\"solisita-you-may-like__track\">\n    {% for related_product in related_collection.products %}\n      {% if related_product.id != product.id and shown_count < 12 %}\n        {% assign shown_count = shown_count | plus: 1 %}\n        {% assign variant = related_product.selected_or_first_available_variant %}\n        {% assign second_image = related_product.images[1] %}\n\n        <div class=\"solisita-like-card\">\n          <a href=\"{{ related_product.url }}\" class=\"solisita-like-card__image\">\n            {% if related_product.compare_at_price_max > related_product.price %}\n              {% assign save_amount = related_product.compare_at_price_max | minus: related_product.price %}\n              {% assign save_percent = save_amount | times: 100 | divided_by: related_product.compare_at_price_max %}\n              <span class=\"solisita-like-card__badge\">-{{ save_percent }}%</span>\n            {% endif %}\n\n            {% if related_product.featured_image %}\n              <img class=\"solisita-like-card__img solisita-like-card__img--main\" src=\"{{ related_product.featured_image | image_url: width: 1000 }}\" alt=\"{{ related_product.featured_image.alt | escape }}\" loading=\"lazy\">\n            {% endif %}\n\n            {% if second_image %}\n              <img class=\"solisita-like-card__img solisita-like-card__img--hover\" src=\"{{ second_image | image_url: width: 1000 }}\" alt=\"{{ second_image.alt | escape }}\" loading=\"lazy\">\n            {% endif %}\n          </a>\n\n          <div class=\"solisita-like-card__body\">\n            <div class=\"solisita-like-card__swatches\">\n              {% assign colour_text = related_product.title | append: ' ' | append: variant.title | downcase %}\n              <span class=\"solisita-like-card__swatch {% if colour_text contains 'silver' %}is-silver{% elsif colour_text contains 'rose' %}is-rose{% elsif colour_text contains 'black' %}is-black{% elsif colour_text contains 'turquoise' %}is-turquoise{% else %}is-gold{% endif %}\"></span>\n            </div>\n\n            <a href=\"{{ related_product.url }}\" class=\"solisita-like-card__title\">{{ related_product.title }}</a>\n\n            {% unless variant.title == 'Default Title' %}\n              <div class=\"solisita-like-card__variant\">{{ variant.title }}</div>\n            {% endunless %}\n\n            <div class=\"solisita-like-card__price\">\n              {% if related_product.compare_at_price_max > related_product.price %}\n                <span class=\"solisita-like-card__compare\">{{ related_product.compare_at_price_max | money }}</span>\n              {% endif %}\n              <span>{{ related_product.price | money }}</span>\n            </div>\n          </div>\n        </div>\n      {% endif %}\n    {% endfor %}\n  </div>\n</section>\n{% endif %}\n\n<script>\n(function(){\n  var section=document.querySelector('[data-solisita-slider]');\n  if(!section)return;\n\n  var track=section.querySelector('.solisita-you-may-like__track');\n  var prev=section.querySelector('.solisita-you-may-like__prev');\n  var next=section.querySelector('.solisita-you-may-like__next');\n  if(!track)return;\n\n  if(prev&&next){\n    function move(dir){\n      var card=track.querySelector('.solisita-like-card');\n      var amount=card?card.offsetWidth+12:420;\n      track.scrollBy({left:amount*dir,behavior:'smooth'});\n    }\n    prev.addEventListener('click',function(){move(-1)});\n    next.addEventListener('click',function(){move(1)});\n  }\n\n  var isDown=false;\n  var startX=0;\n  var startScroll=0;\n  var lastX=0;\n  var lastTime=0;\n  var velocity=0;\n  var moved=false;\n  var raf=null;\n  var momentumFrame=null;\n  var targetScroll=0;\n\n  function setScroll(value){\n    targetScroll=value;\n    if(raf)return;\n    raf=requestAnimationFrame(function(){\n      track.scrollLeft=targetScroll;\n      raf=null;\n    });\n  }\n\n  function stopMomentum(){\n    if(momentumFrame){\n      cancelAnimationFrame(momentumFrame);\n      momentumFrame=null;\n    }\n  }\n\n  function momentum(){\n    velocity*=0.94;\n    if(Math.abs(velocity)<0.15){\n      momentumFrame=null;\n      return;\n    }\n    track.scrollLeft-=velocity;\n    momentumFrame=requestAnimationFrame(momentum);\n  }\n\n  track.addEventListener('pointerdown',function(e){\n    if(e.button!==undefined&&e.button!==0)return;\n    isDown=true;\n    moved=false;\n    startX=e.clientX;\n    lastX=e.clientX;\n    startScroll=track.scrollLeft;\n    lastTime=performance.now();\n    velocity=0;\n    stopMomentum();\n    track.classList.add('is-dragging');\n    if(track.setPointerCapture)track.setPointerCapture(e.pointerId);\n  });\n\n  track.addEventListener('pointermove',function(e){\n    if(!isDown)return;\n\n    var now=performance.now();\n    var dx=e.clientX-startX;\n    var moveX=e.clientX-lastX;\n    var dt=now-lastTime||16;\n\n    if(Math.abs(dx)>6)moved=true;\n\n    velocity=moveX/dt*16;\n    setScroll(startScroll-dx);\n\n    lastX=e.clientX;\n    lastTime=now;\n  });\n\n  function endDrag(e){\n    if(!isDown)return;\n    isDown=false;\n    track.classList.remove('is-dragging');\n\n    if(e&&track.releasePointerCapture){\n      try{track.releasePointerCapture(e.pointerId)}catch(err){}\n    }\n\n    if(Math.abs(velocity)>0.4){\n      stopMomentum();\n      momentumFrame=requestAnimationFrame(momentum);\n    }\n\n    setTimeout(function(){moved=false},90);\n  }\n\n  track.addEventListener('pointerup',endDrag);\n  track.addEventListener('pointercancel',endDrag);\n  track.addEventListener('pointerleave',endDrag);\n\n  track.addEventListener('click',function(e){\n    if(moved){\n      e.preventDefault();\n      e.stopPropagation();\n    }\n  },true);\n})();\n</script>"
      }
    }
  },
