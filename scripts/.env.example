# DeepSeek V4 Pro API Key (required)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek model — V4 Pro
DEEPSEEK_MODEL=deepseek-chat

# DeepSeek API endpoint
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Shopify credentials — copied from Solisita Admin_API
SHOPIFY_SHOP_DOMAIN=bgikuj-su.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_shopify_token_here
SHOPIFY_API_VERSION=2024-04

# Execution mode: dry-run=preview only, apply=write back to Shopify
EXECUTION_MODE=dry-run
# Product limit per run (0 = all)
PRODUCT_LIMIT=5
# Minimum description length (chars) to trigger rewrite
MIN_DESC_LENGTH=100
# Maximum description length (chars) before truncation is considered
MAX_DESC_LENGTH=800
# Skip products matching these words in title (comma-separated, empty = none)
SKIP_TITLE_WORDS=
# Only process products with these tags (comma-separated, empty = all)
FILTER_TAGS=
