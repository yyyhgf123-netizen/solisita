{%- assign group_product 			= product.metafields.bwp_fields.group_product -%}
{%- assign current_variant 			= product.selected_or_first_available_variant -%}
{%- if group_product != blank -%}
    <div class="price-container" style="margin:{{ block.settings.product_price_margin }};--price-color:{{ block.settings.price_color }};--price-color-sale:{{ block.settings.price_color_sale }};--price-font-size:{{ block.settings.price_size }}px;">
        {% for product_group in group_product.value %}
            {%- for variant in product_group.variants -%}
                {% assign prices =  prices | append: variant.price | append: ',' %}
            {% endfor %}
        {% endfor %}
        {% assign operator_prices	= prices | split: "," %}
        {% assign min_price = operator_prices[0] | plus: 0 %}
        {% assign max_price = operator_prices[0] | plus: 0 %}
        {% for operator_price in operator_prices %}
            {% assign operator = operator_price | plus: 0 %}
            {% assign min_price		 = min_price | plus: 0 %}
            {% assign max_price		 = max_price | plus: 0 %}
            {% if operator < min_price %}
                {% assign min_price = operator %}
            {% endif %}
            {% if operator > max_price %}
                {% assign max_price = operator %}
            {% endif %}		
        {% endfor %}
        {{  min_price | money }} - {{  max_price | money }}
    </div>
{% else %}
    <div class="price-single-product" style="margin:{{ block.settings.product_price_margin }};--price-color:{{ block.settings.price_color }};--price-color-sale:{{ block.settings.price_color_sale }};--price-font-size:{{ block.settings.price_size }}px;">
        {% render 'product-price', variant: current_variant %}
    </div>
{% endif %}
{% schema %}
  {
    "name": "Single product price",
    "settings": [
        {
            "type": "text",
            "id": "product_price_margin",
            "label": "Margin",
            "info": "Example(top left bottom right): 15px 15px 15px 15px",
            "default":"10px 0 17px"
        },
        {
            "type": "number",
            "id": "price_size",
            "label": "Font size",
            "info": "px",
            "default":25
        },
        {
            "type": "color",
            "id": "price_color",
            "label": "Color",
            "default":"#ed5d43"
        },
        {
            "type": "color",
            "id": "price_color_sale",
            "label": "Color sale",
            "default":"#ff0000"
        }
    ],
    "presets": [{"name": "Single product price","category": "Single product"}]
  }
{% endschema %}