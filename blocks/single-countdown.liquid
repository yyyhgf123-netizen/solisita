{%- if block.settings.metafield_product_countdowns != blank -%}
<div class="countdown-single"{% if block.settings.product_countdowns_margin != blank %} style="margin:{{ block.settings.product_countdowns_margin }}"{% endif %}>
    <div class="title-countdown">
        <span class="icon">
            <svg xmlns="http://www.w3.org/2000/svg" version="1.1" xmlns:xlink="http://www.w3.org/1999/xlink" width="1em" height="1em" x="0" y="0" viewBox="0 0 443.294 443.294" style="enable-background:new 0 0 512 512" xml:space="preserve" class=""><g><path d="M221.647 0C99.433 0 0 99.433 0 221.647s99.433 221.647 221.647 221.647 221.647-99.433 221.647-221.647S343.861 0 221.647 0zm0 415.588c-106.941 0-193.941-87-193.941-193.941s87-193.941 193.941-193.941 193.941 87 193.941 193.941-87 193.941-193.941 193.941z" fill="" opacity="1" data-original="" class=""></path><path d="M235.5 83.118h-27.706v144.265l87.176 87.176 19.589-19.589-79.059-79.059z" fill="" opacity="1" data-original="" class=""></path></g></svg>
        </span>
        <label>{{ block.settings.product_countdown_title }}</label>
    </div>
    <div class="countdown" data-countdown_single="{{ block.settings.metafield_product_countdowns }}" data-day="{{ block.settings.product_countdown_day }}" data-hour="{{ block.settings.product_countdown_hour }}" data-min="{{ block.settings.product_countdown_min }}" data-sec="{{ block.settings.product_countdown_sec }}"></div>
</div>
{%- endif -%}
{% schema %}
  {
    "name": "Single product countdown",
    "settings": [
        {
            "type": "text",
            "id": "metafield_product_countdowns",
            "label": "Metafiled Countdown"
        },
        {
            "type": "text",
            "id": "product_countdowns_margin",
            "label": "Margin",
            "info": "Example(top left bottom right): 15px 15px 15px 15px"
        },
        {
            "type": "header",
            "content": "Product countdowns"
        },
        {
            "type": "text",
            "id": "product_countdown_title",
            "label": "Title CountDown",
            "default": "Hurry up! Sale ends in :"
        },
            {
            "type": "text",
            "id": "product_countdown_day",
            "label": "Text day",
            "default": "d"
        },
        {
            "type": "text",
            "id": "product_countdown_hour",
            "label": "Text hour",
            "default": "h"
        },
        {
            "type": "text",
            "id": "product_countdown_min",
            "label": "Text minutes",
            "default": "m"
        },
        {
            "type": "text",
            "id": "product_countdown_sec",
            "label": "Text second",
            "default": "s"
        }
    ],
    "presets": [{"name": "Single product countdown","category": "Single product"}]
  }
{% endschema %}