        },
        {
          "type": "range",
          "id": "column1",
          "min": 1,
          "max": 7,
          "step": 0.5,
          "label": "Columns",
          "default": 4
        },
        {
          "type": "range",
          "id": "pergroup_column1",
          "min": 1,
          "max": 7,
          "step": 1,
          "label": "Group",
          "default": 4
        },
