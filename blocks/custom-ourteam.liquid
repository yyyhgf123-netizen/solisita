{%- style -%}
     #shopify-section-{{ section.id }} .wpbingo-widget--ourteam .ourteam-card__avatar{
        border-radius: {{ block.settings.border_image }};
    }
    #shopify-section-{{ section.id }} .wpbingo-widget--ourteam .info {
        text-align:{{ block.settings.align }};
    }
    #shopify-section-{{ section.id }} .wpbingo-widget--ourteam .ourteam-card__name{
        color:{{block.settings.color_title}};
        font-size:{{block.settings.font_size_title}}px;
        line-height:{{block.settings.line_height_title}}px;
        font-weight:{{block.settings.font_weight_title}};
        letter-spacing:{{block.settings.letter_spacing_title}}px;
        text-transform:{{ block.settings.text_transform }};
        margin:{{block.settings.margin}};
    }
    #shopify-section-{{ section.id }} .wpbingo-widget--ourteam .ourteam-card__job{
        color:{{block.settings.color_job}};
        font-size:{{block.settings.font_size_job}}px;
        line-height:{{block.settings.line_height_job}}px;
        font-weight:{{block.settings.font_weight_job}};
        letter-spacing:{{block.settings.letter_spacing_job}}px;
    }
    #shopify-section-{{ section.id }} .wpbingo-widget--ourteam .social-icons li a{
         width:{{block.settings.width}}px;
         height:{{block.settings.height}}px;
         color: {{block.settings.color}};
         font-size:{{block.settings.font_size}}px;
         background: {{block.settings.background}};
         fill: {{block.settings.color}};
         display: inline-flex;
        justify-content: center;
        align-items: center;
         border-radius:{{block.settings.border_radius}};
        {%- if block.settings.border -%}
            border-width:1px;
            border-color:{{ block.settings.border_color }};
            border-style:solid;
        {%- endif -%}
    }
    #shopify-section-{{ section.id }} .wpbingo-widget--ourteam .social-icons li a:hover{
         color: {{block.settings.color_hover}};
          fill: {{block.settings.color_hover}};
          background: {{block.settings.background_hover}};
          {%- if block.settings.border -%}
              border-color:{{ block.settings.border_color_hover }};
          {%- endif -%}
    }
    @media(max-width:767px){
        #shopify-section-{{ section.id }} .wpbingo-widget--ourteam .ourteam-card__name{
            font-size:{{block.settings.font_size_title_mobi}}px;
            line-height:{{block.settings.line_height_title_mobi}}px;
            letter-spacing:{{block.settings.letter_spacing_title_mobi}}px;
            margin:{{block.settings.margin_mobi}};
        }
        #shopify-section-{{ section.id }} .wpbingo-widget--ourteam .ourteam-card__job{
            font-size:{{block.settings.font_size_job_mobi}}px;
            line-height:{{block.settings.line_height_job_mobi}}px;
            letter-spacing:{{block.settings.letter_spacing_job_mobi}}px;
        }
    }
{%- endstyle -%}
