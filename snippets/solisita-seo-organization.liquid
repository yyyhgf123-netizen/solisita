{%- comment -%}
  ============================================================================
  SOLISITA SEO — Organization + WebSite Structured Data Module
  ============================================================================
  Dependency: ZERO. Reads from shop + settings global objects.
  Renders:    <script type="application/ld+json">Organization + WebSite</script>
  Placement:  In <head> via theme.liquid — all pages.
  ============================================================================
{%- endcomment -%}

{%- capture same_as -%}
[{%- if settings.social_facebook_link != blank -%}"{{ settings.social_facebook_link }}"{%- endif -%}{%- if settings.social_instagram_link != blank -%}{% if settings.social_facebook_link != blank %},{% endif %}"{{ settings.social_instagram_link }}"{%- endif -%}{%- if settings.social_pinterest_link != blank -%}{% if settings.social_facebook_link != blank or settings.social_instagram_link != blank %},{% endif %}"{{ settings.social_pinterest_link }}"{%- endif -%}{%- if settings.social_tiktok_link != blank -%}{% if settings.social_facebook_link != blank or settings.social_instagram_link != blank or settings.social_pinterest_link != blank %},{% endif %}"{{ settings.social_tiktok_link }}"{%- endif -%}{%- if settings.social_youtube_link != blank -%}{% if settings.social_facebook_link != blank or settings.social_instagram_link != blank or settings.social_pinterest_link != blank or settings.social_tiktok_link != blank %},{% endif %}"{{ settings.social_youtube_link }}"{%- endif -%}{%- if settings.social_twitter_link != blank -%}{% if settings.social_facebook_link != blank or settings.social_instagram_link != blank or settings.social_pinterest_link != blank or settings.social_tiktok_link != blank or settings.social_youtube_link != blank %},{% endif %}"{{ settings.social_twitter_link }}"{%- endif -%}]
{%- endcapture -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": {{ shop.url | append: '#organization' | json }},
  "name": {{ shop.name | json }},
  "url": {{ shop.url | json }},
  "description": {{ shop.description | default: shop.name | json }},
  {%- if settings.share_image %}
  "logo": "https:{{ settings.share_image | image_url: '600x' }}",
  {%- endif -%}
  {%- if settings.social_facebook_link != blank or settings.social_instagram_link != blank %}
  "sameAs": {{ same_as | strip_newlines | strip }}
  {%- endif -%}
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": {{ shop.url | append: '#website' | json }},
  "name": {{ shop.name | json }},
  "url": {{ shop.url | json }},
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "{{ shop.url }}/search?q={% raw %}{search_term_string}{% endraw %}"
    },
    "query-input": "required name=search_term_string"
  }
}
</script>
